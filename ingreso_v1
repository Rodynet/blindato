<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blindato - Onboarding App</title>
    <style>
        :root {
            --primary-color: #0f172a;
            --accent-color: #3b82f6;
            --bg-color: #f8fafc;
            --text-color: #334155;
            --card-bg: #ffffff;
        }

        body {
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: #e2e8f0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        /* Simulación de pantalla de celular */
        .mobile-container {
            width: 375px;
            height: 812px;
            background-color: var(--bg-color);
            border-radius: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            overflow: hidden;
            position: relative;
            border: 8px solid #1e293b;
        }

        .screen {
            padding: 40px 24px;
            height: 100%;
            box-sizing: border-box;
            display: none;
            flex-direction: column;
            animation: fadeIn 0.3s ease-in-out;
        }

        .screen.active {
            display: flex;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 40px;
            margin-top: 20px;
        }

        .logo-container h1 {
            color: var(--primary-color);
            font-size: 28px;
            margin: 0;
            letter-spacing: 1px;
        }

        .logo-container p {
            color: var(--accent-color);
            font-size: 14px;
            margin: 5px 0 0 0;
            font-weight: 600;
        }

        h2 {
            color: var(--primary-color);
            font-size: 22px;
            margin-bottom: 8px;
        }

        p.subtitle {
            color: #64748b;
            font-size: 14px;
            margin-bottom: 30px;
        }

        /* Formularios y Botones */
        .input-group {
            margin-bottom: 20px;
        }

        input[type="email"], input[type="password"] {
            width: 100%;
            padding: 15px;
            border: 1px solid #cbd5e1;
            border-radius: 12px;
            box-sizing: border-box;
            font-size: 16px;
            background-color: var(--card-bg);
        }

        .btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 12px;
        }

        .btn-primary {
            background-color: var(--primary-color);
            color: white;
        }

        .btn-primary:hover {
            background-color: #1e293b;
        }

        .btn-outline {
            background-color: transparent;
            border: 2px solid #cbd5e1;
            color: var(--text-color);
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 20px 0;
            color: #94a3b8;
            font-size: 14px;
        }

        .divider::before, .divider::after {
            content: '';
            flex: 1;
            border-bottom: 1px solid #cbd5e1;
        }

        .divider:not(:empty)::before { margin-right: .25em; }
        .divider:not(:empty)::after { margin-left: .25em; }

        /* Selector de Perfil Cards */
        .profile-card {
            background-color: var(--card-bg);
            border: 2px solid #e2e8f0;
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 16px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
        }

        .profile-card:hover, .profile-card:active {
            border-color: var(--accent-color);
            background-color: #eff6ff;
        }

        .profile-icon {
            font-size: 24px;
            margin-right: 15px;
            background: #e0e7ff;
            padding: 12px;
            border-radius: 50%;
        }

        .profile-text h3 {
            margin: 0 0 5px 0;
            font-size: 16px;
            color: var(--primary-color);
        }

        .profile-text p {
            margin: 0;
            font-size: 13px;
            color: #64748b;
        }

        /* Infoexperto ID */
        .kyc-box {
            background-color: #f1f5f9;
            border: 2px dashed #cbd5e1;
            border-radius: 16px;
            padding: 30px 20px;
            text-align: center;
            margin-bottom: 20px;
            cursor: pointer;
        }

        .kyc-box.success {
            border-color: #22c55e;
            background-color: #f0fdf4;
            color: #166534;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>

    <div class="mobile-container">
        
        <!-- PANTALLA 1: ACCESO UNIVERSAL -->
        <div id="screen1" class="screen active">
            <div class="logo-container">
                <h1>BLINDATO</h1>
                <p>Secretaría Digital Autónoma</p>
            </div>

            <h2>Bienvenido</h2>
            <p class="subtitle">Acceso universal a tu ecosistema</p>

            <div class="input-group">
                <input type="email" placeholder="Mail" required>
            </div>
            <div class="input-group">
                <input type="password" placeholder="Contraseña" required>
            </div>

            <button class="btn btn-primary" onclick="nextScreen('screen2')">Ingresar</button>

            <div class="divider">O ingresa con</div>

            <button class="btn btn-outline">
                🍎 Apple SSO
            </button>
            <button class="btn btn-outline">
                🇬 Google SSO
            </button>
        </div>

        <!-- PANTALLA 2: SELECTOR DE PERFIL -->
        <div id="screen2" class="screen">
            <div class="logo-container" style="margin-bottom: 20px;">
                <h1>BLINDATO</h1>
            </div>

            <h2>¿Cómo deseas operar hoy?</h2>
            <p class="subtitle">Selecciona tu perfil para adaptar tu interfaz.</p>

            <div class="profile-card" onclick="nextScreen('screen3')">
                <div class="profile-icon">🏠</div>
                <div class="profile-text">
                    <h3>Soy Inquilino</h3>
                    <p>Busco alquilar o gestionar mi pago mensual, ver mi score y beneficios.</p>
                </div>
            </div>

            <div class="profile-card" onclick="nextScreen('screen3')">
                <div class="profile-icon">🔑</div>
                <div class="profile-text">
                    <h3>Soy Propietario</h3>
                    <p>Tengo propiedades en alquiler, quiero ver mis cobros y rendimiento.</p>
                </div>
            </div>

            <div class="profile-card" onclick="nextScreen('screen3')">
                <div class="profile-icon">🏢</div>
                <div class="profile-text">
                    <h3>Soy Administrador</h3>
                    <p>Gestión de inmobiliaria (Redirige a acceso optimizado Desktop/Web).</p>
                </div>
            </div>
        </div>

        <!-- PANTALLA 3: IDENTIDAD (INFOEXPERTO-ID) -->
        <div id="screen3" class="screen">
            <div style="text-align: center; margin-bottom: 20px;">
                <span style="font-size: 40px;">🛡️</span>
            </div>
            <h2>Identidad y Seguridad</h2>
            <p class="subtitle">Paso obligatorio (Infoexperto-ID) para activar tu rol financiero y garantizar la seguridad del ecosistema.</p>

            <div class="kyc-box" id="dni-box" onclick="simulateKYC(this)">
                <div style="font-size: 30px; margin-bottom: 10px;">🪪</div>
                <h3 style="margin: 0;">Escanear DNI</h3>
                <p style="margin: 5px 0 0 0; font-size: 13px; color: #64748b;">Frente y dorso</p>
            </div>

            <div class="kyc-box" id="selfie-box" onclick="simulateKYC(this)">
                <div style="font-size: 30px; margin-bottom: 10px;">🤳</div>
                <h3 style="margin: 0;">Biometría (Identity Match)</h3>
                <p style="margin: 5px 0 0 0; font-size: 13px; color: #64748b;">Prueba de vida con cámara frontal</p>
            </div>

            <button class="btn btn-primary" style="margin-top: auto;" onclick="alert('¡Validación exitosa! Avanzando al Dashboard / Mago de Carga.')">Validar Identidad</button>
        </div>

    </div>

    <script>
        function nextScreen(screenId) {
            // Ocultar todas las pantallas
            document.querySelectorAll('.screen').forEach(screen => {
                screen.classList.remove('active');
            });
            // Mostrar la pantalla solicitada
            document.getElementById(screenId).classList.add('active');
        }

        function simulateKYC(element) {
            element.classList.add('success');
            element.innerHTML = '✅<br><h3 style="margin: 10px 0 0 0;">Verificado exitosamente</h3>';
        }
    </script>
</body>
</html>
